# ── Raqib environment ─────────────────────────────────────────────────────
# Neon Postgres (Vercel → Storage → Neon, or neon.tech). Use the POOLED url.
DATABASE_URL="postgres://USER:PASSWORD@HOST/neondb?sslmode=require"

# Session signing secret (HMAC-SHA256). Generate: openssl rand -hex 32
SESSION_SECRET="CHANGE_ME_min_32_chars"

# MFA secret-at-rest key (AES-256-GCM). Exactly 64 hex chars. Generate: openssl rand -hex 32
DATA_ENC_KEY="CHANGE_ME_64_hex_chars"

# Anthropic API key — server-side only, never exposed to the browser.
ANTHROPIC_API_KEY="sk-ant-..."
